{
  "runtime": {
    "llamaCpp": {
      "provider": "github-release",
      "repo": "ggml-org/llama.cpp",
      "assetPattern": "^llama-.*-bin-win-cpu-x64\\.zip$",
      "targetDir": "runtime/llama.cpp",
      "extract": "zip"
    },
    "portableGit": {
      "provider": "github-release",
      "repo": "git-for-windows/git",
      "assetPattern": "^PortableGit-.*-64-bit\\.7z\\.exe$",
      "targetDir": "runtime/PortableGit",
      "extract": "7z-sfx"
    },
    "winPython": {
      "provider": "github-release",
      "repo": "winpython/winpython",
      "releaseTag": "16.6.20250620final",
      "assetPattern": "^WinPython64-3\\.12\\..*dot\\.zip$",
      "targetDir": "runtime/WinPython",
      "extract": "zip"
    }
  },
  "models": {
    "qwen": {
      "enabled": true,
      "provider": "huggingface",
      "repo": "Qwen/Qwen2.5-Coder-7B-Instruct-GGUF",
      "filePattern": "qwen2.5-coder-7b-instruct-q4_k_m.gguf",
      "targetDir": "models/qwen2.5-coder-7b-instruct-q4"
    },
    "gemma4": {
      "enabled": true,
      "provider": "huggingface",
      "repo": "ggml-org/gemma-4-E4B-it-GGUF",
      "filePattern": "gemma-4-e4b-it-Q4_K_M.gguf",
      "targetDir": "models/gemma4-e4b-it-q4",
      "note": "Official GGUF route for Gemma 4 E4B Instruct via ggml-org."
    }
  }
}
